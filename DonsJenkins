pipeline {
    agent any
    parameters {
    string(name:'Branch_name', defaultValue:'main', description:'enter to build')
    choice(name: 'CHOICES', choices: ['one', 'two', 'three'], description: '')
    }
       stages {
        stage('Hello') {
            environment {
            VERSION = '1.2.0'
            }
            steps {
                echo 'Hello'
                echo $VERSION
            }
        }

               stage('Git Clone') {
            steps {
                echo 'Cloning from GitHub'
                git branch: '$Branch_name', changelog: false, credentialsId: 'For-github', poll: false, url: 'https://github.com/IBT-learning/DevOps-Git/'
            }
        }
        stage('Git Verify') {
            steps {
                bat 'dir'
            }
        }
          
          stage('Adding stage from DonsJenkins') {
            when {
                expression{
                Branch_name == 'main'
            }
         }
         stage('Sending email') {
         steps {emailext attachLog: true, body: 'from testing pipeline...', replyTo: 'no-reply@ibt-jenkins.co', subject: 'Testing', to: 'danny.banny606@gmail.com'
         }
         }

   }
   post {
   always {
   echo 'I will always say hello again!'
   }
   }
}
